+# Copyright 2026 Free Software Foundation, Inc.
+#
+# Copying and distribution of this file, with or without modification,
+# in any medium, are permitted without royalty provided the copyright
+# notice and this notice are preserved.
+
+# Comprehensive interoperability tests with git:
+# - Binary diffs (literal and delta) generated by git
+# - Rename patches (with and without content changes)
+# - Copy patches (with and without content changes)
+# - Combinations: binary rename/copy, mixed text+binary, concatenated
+
+. $srcdir/test-lib.sh
+
+require cat
+require git
+use_local_patch
+use_tmpdir
+
+# ==============================================================
+# Helper to create a git repo with various binary content
+
+setup_git_repo() {
+    rm -rf repo work
+    mkdir repo work
+    cd repo
+    git init -q
+    git config user.email "test@test.com"
+    git config user.name "Test"
+}
+
+# ==============================================================
+# PART 1: Git binary diff round-trip tests
+# ==============================================================
+
+setup_git_repo
+
+# Create a 200-byte binary file with recognizable pattern
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(200)))
+" > bindata
+git add bindata
+git commit -q -m "add bindata"
+
+# Modify a few bytes
+python3 -c "
+import sys
+d = bytearray(range(200))
+d[50] = 0xAA
+d[100] = 0xBB
+d[150] = 0xCC
+sys.stdout.buffer.write(bytes(d))
+" > bindata
+git add bindata
+git commit -q -m "modify bindata"
+
+git diff --binary HEAD~1 HEAD > ../modify-bindata.diff
+cd ..
+
+# Apply the patch using our patch tool and verify round-trip
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(200)))
+" > work/bindata
+
+check 'cd work && patch -p1 < ../modify-bindata.diff || echo "Status: $?"' <<EOF
+patching file bindata (binary)
+EOF
+
+# Verify the content matches what git produced
+check 'python3 -c "
+import sys
+with open(\"work/bindata\", \"rb\") as f:
+    d = f.read()
+expected = bytearray(range(200))
+expected[50] = 0xAA
+expected[100] = 0xBB
+expected[150] = 0xCC
+if d == bytes(expected):
+    print(\"match\")
+else:
+    print(\"mismatch\")
+    for i in range(200):
+        if d[i] != expected[i]:
+            sys.stderr.write(\"byte %d: got %02x expected %02x\n\" % (i, d[i], expected[i]))
+"' <<EOF
+match
+EOF
+
+# Reverse the patch
+check 'cd work && patch -R -p1 < ../modify-bindata.diff || echo "Status: $?"' <<EOF
+patching file bindata (binary)
+EOF
+
+check 'python3 -c "
+with open(\"work/bindata\", \"rb\") as f:
+    d = f.read()
+if d == bytes(range(200)):
+    print(\"match\")
+else:
+    print(\"mismatch\")
+"' <<EOF
+match
+EOF
+
+# ==============================================================
+# PART 2: Git rename with text changes (similar enough for -M)
+# ==============================================================
+
+setup_git_repo
+
+printf "line1\nline2\nline3\nline4\nline5\n" > textfile
+git add textfile
+git commit -q -m "add textfile"
+
+git mv textfile renamed
+printf "line1\nline2\nmodified\nline4\nline5\n" > renamed
+git add renamed
+git commit -q -m "rename and modify"
+
+git diff --binary -M HEAD~1 HEAD > ../rename-text.diff
+cd ..
+
+printf "line1\nline2\nline3\nline4\nline5\n" > work/textfile
+
+check 'cd work && patch -p1 < ../rename-text.diff || echo "Status: $?"' <<EOF
+patching file renamed (renamed from textfile)
+EOF
+
+ncheck 'test ! -e work/textfile'
+
+check 'cat work/renamed' <<EOF
+line1
+line2
+modified
+line4
+line5
+EOF
+
+# ==============================================================
+# PART 3: Git copy with text changes (similar enough for -C)
+# ==============================================================
+
+setup_git_repo
+
+printf "line1\nline2\nline3\nline4\nline5\n" > original
+git add original
+git commit -q -m "add original"
+
+cp original copied
+printf "line1\nline2\nchanged\nline4\nline5\n" > copied
+git add copied
+git commit -q -m "copy and modify"
+
+git diff --binary -C -C HEAD~1 HEAD > ../copy-text.diff
+cd ..
+
+printf "line1\nline2\nline3\nline4\nline5\n" > work/original
+
+check 'cd work && patch -p1 < ../copy-text.diff || echo "Status: $?"' <<EOF
+patching file copied (copied from original)
+EOF
+
+# Original should be unchanged
+check 'cat work/original' <<EOF
+line1
+line2
+line3
+line4
+line5
+EOF
+
+check 'cat work/copied' <<EOF
+line1
+line2
+changed
+line4
+line5
+EOF
+
+# ==============================================================
+# PART 4: Git rename of binary file (no content change)
+# ==============================================================
+
+setup_git_repo
+
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(100)))
+" > binaryold
+git add binaryold
+git commit -q -m "add binaryold"
+
+git mv binaryold binarynew
+git commit -q -m "rename binary"
+
+git diff --binary -M HEAD~1 HEAD > ../rename-binary.diff
+cd ..
+
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(100)))
+" > work/binaryold
+
+check 'cd work && patch -p1 < ../rename-binary.diff || echo "Status: $?"' <<EOF
+patching file binarynew (renamed from binaryold)
+EOF
+
+ncheck 'test ! -e work/binaryold'
+
+check 'python3 -c "
+with open(\"work/binarynew\", \"rb\") as f:
+    d = f.read()
+if d == bytes(range(100)):
+    print(\"match\")
+else:
+    print(\"mismatch\")
+"' <<EOF
+match
+EOF
+
+# ==============================================================
+# PART 5: Git rename of binary file WITH content changes
+# ==============================================================
+
+setup_git_repo
+
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(100)))
+" > binaryold
+git add binaryold
+git commit -q -m "add binaryold"
+
+git mv binaryold binarynew
+python3 -c "
+import sys
+d = bytearray(range(100))
+d[0] = 0xFF
+sys.stdout.buffer.write(bytes(d))
+" > binarynew
+git add binarynew
+git commit -q -m "rename and modify binary"
+
+git diff --binary -M HEAD~1 HEAD > ../rename-modify-binary.diff
+cd ..
+
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(100)))
+" > work/binaryold
+rm -f work/binarynew
+
+check 'cd work && patch -p1 < ../rename-modify-binary.diff || echo "Status: $?"' <<EOF
+patching file binarynew (renamed from binaryold) (binary)
+EOF
+
+ncheck 'test ! -e work/binaryold'
+
+check 'python3 -c "
+with open(\"work/binarynew\", \"rb\") as f:
+    d = f.read()
+expected = bytearray(range(100))
+expected[0] = 0xFF
+if d == bytes(expected):
+    print(\"match\")
+else:
+    print(\"mismatch\")
+"' <<EOF
+match
+EOF
+
+# ==============================================================
+# PART 5b: Git copy of binary file WITH content changes
+# ==============================================================
+
+setup_git_repo
+
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(100)))
+" > binaryorig
+git add binaryorig
+git commit -q -m "add binaryorig"
+
+cp binaryorig binarycopy
+python3 -c "
+import sys
+d = bytearray(range(100))
+d[0] = 0xFF
+sys.stdout.buffer.write(bytes(d))
+" > binarycopy
+git add binarycopy
+git commit -q -m "copy and modify binary"
+
+git diff --binary -C -C HEAD~1 HEAD > ../copy-modify-binary.diff
+cd ..
+
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(100)))
+" > work/binaryorig
+rm -f work/binarycopy
+
+check 'cd work && patch -p1 < ../copy-modify-binary.diff || echo "Status: $?"' <<EOF
+patching file binarycopy (copied from binaryorig) (binary)
+EOF
+
+# Original should still exist
+check 'test -f work/binaryorig && echo "exists"' <<EOF
+exists
+EOF
+
+check 'python3 -c "
+with open(\"work/binarycopy\", \"rb\") as f:
+    d = f.read()
+expected = bytearray(range(100))
+expected[0] = 0xFF
+if d == bytes(expected):
+    print(\"match\")
+else:
+    print(\"mismatch\")
+"' <<EOF
+match
+EOF
+
+# ==============================================================
+# PART 6: Larger binary file test (ensures multi-line base85)
+# ==============================================================
+
+setup_git_repo
+
+python3 -c "
+import sys
+# Create a 4096-byte binary blob with null bytes to force binary detection
+data = bytearray(range(256)) * 16  # 4096 bytes, contains null bytes
+sys.stdout.buffer.write(bytes(data))
+" > largebin
+git add largebin
+git commit -q -m "add largebin"
+
+python3 -c "
+import sys
+data = bytearray(range(256)) * 16
+data[0] = 0x42
+data[2048] = 0x43
+sys.stdout.buffer.write(bytes(data))
+" > largebin
+git add largebin
+git commit -q -m "modify largebin"
+
+git diff --binary HEAD~1 HEAD > ../modify-large.diff
+cd ..
+
+python3 -c "
+import sys
+data = bytearray(range(256)) * 16
+sys.stdout.buffer.write(bytes(data))
+" > work/largebin
+
+check 'cd work && patch -p1 < ../modify-large.diff || echo "Status: $?"' <<EOF
+patching file largebin (binary)
+EOF
+
+check 'python3 -c "
+import sys
+with open(\"work/largebin\", \"rb\") as f:
+    d = bytearray(f.read())
+expected = bytearray(range(256)) * 16
+expected[0] = 0x42
+expected[2048] = 0x43
+if d == bytes(expected):
+    print(\"match\")
+else:
+    print(\"mismatch\")
+"' <<EOF
+match
+EOF
+
+# ==============================================================
+# PART 7: Mixed text and binary patches in one diff
+# ==============================================================
+
+setup_git_repo
+git commit --allow-empty -q -m "init"
+
+echo "text content" > textfile
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(50)))
+" > binfile
+git add textfile binfile
+git commit -q -m "add files"
+
+echo "modified text" > textfile
+python3 -c "
+import sys
+d = bytearray(range(50))
+d[25] = 0xFF
+sys.stdout.buffer.write(bytes(d))
+" > binfile
+git add textfile binfile
+git commit -q -m "modify both"
+
+git diff --binary HEAD~1 HEAD > ../mixed.diff
+cd ..
+
+echo "text content" > work/textfile
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(50)))
+" > work/binfile
+
+check 'cd work && patch -p1 < ../mixed.diff || echo "Status: $?"' <<EOF
+patching file binfile (binary)
+patching file textfile
+EOF
+
+check 'cat work/textfile' <<EOF
+modified text
+EOF
+
+check 'python3 -c "
+with open(\"work/binfile\", \"rb\") as f:
+    d = bytearray(f.read())
+expected = bytearray(range(50))
+expected[25] = 0xFF
+if d == expected:
+    print(\"match\")
+else:
+    print(\"mismatch\")
+"' <<EOF
+match
+EOF
+
+# ==============================================================
+# PART 8: Verify git apply and GNU patch produce same results
+# ==============================================================
+
+setup_git_repo
+
+python3 -c "
+import sys
+sys.stdout.buffer.write(bytes(range(200)))
+" > bindata
+git add bindata
+git commit -q -m "add bindata"
+
+python3 -c "
+import sys
+d = bytearray(range(200))
+d[10] = 0xDE
+d[20] = 0xAD
+d[30] = 0xBE
+d[40] = 0xEF
+sys.stdout.buffer.write(bytes(d))
+" > bindata
+git add bindata
+git commit -q -m "modify bindata"
+
+git diff --binary HEAD~1 HEAD > ../interop.diff
+
+# Apply with git apply
+git checkout HEAD~1 -- bindata 2>/dev/null
+cp bindata ../git_original
+git apply ../interop.diff
+cp bindata ../git_result
+
+cd ..
+
+# Apply with GNU patch
+cp git_original work/bindata
+cd work && patch -p1 < ../interop.diff >/dev/null 2>&1
+cd ..
+
+check 'cmp work/bindata git_result && echo "identical"' <<EOF
+identical
+EOF
+
+rm -rf repo work *.diff git_original git_result
