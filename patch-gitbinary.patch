+/* git binary patch support for GNU patch */
+
+/* Copyright 2026 Free Software Foundation, Inc.
+
+   This program is free software: you can redistribute it and/or modify
+   it under the terms of the GNU General Public License as published by
+   the Free Software Foundation, either version 3 of the License, or
+   (at your option) any later version.
+
+   This program is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+   GNU General Public License for more details.
+
+   You should have received a copy of the GNU General Public License
+   along with this program.  If not, see <http://www.gnu.org/licenses/>.  */
+
+#ifndef GITPATCH_H
+#define GITPATCH_H
+
+#include <stddef.h>
+#include <stdbool.h>
+
+/* Type of git binary patch hunk.  */
+enum git_binary_type {
+  GIT_BINARY_LITERAL,
+  GIT_BINARY_DELTA
+};
+
+/* A parsed git binary patch hunk (one direction).  */
+struct git_binary_hunk {
+  enum git_binary_type type;
+  size_t result_size;      /* For literal: uncompressed data size.
+                              For delta: uncompressed delta size.  */
+  unsigned char *data;     /* The decoded (base85-decoded, zlib-inflated) data.  */
+  size_t data_len;         /* Length of decoded data.  */
+};
+
+/* A complete git binary patch (forward + reverse).  */
+struct git_binary_patch {
+  struct git_binary_hunk forward;
+  struct git_binary_hunk reverse;
+};
+
+/* Decode a base85 line.  DST must have room for LEN bytes.
+   LINE is the base85-encoded data (without the length character).
+   LINE_LEN is the number of base85 characters.
+   Returns true on success, false on error.  */
+bool git_base85_decode (unsigned char *dst, size_t len,
+                        const char *line, size_t line_len);
+
+/* Apply a git binary delta to a source buffer, producing a result buffer.
+   DELTA and DELTA_LEN describe the uncompressed delta data.
+   SRC and SRC_LEN describe the original file content.
+   On success, sets *RESULT and *RESULT_LEN and returns true.
+   Caller must free *RESULT.  */
+bool git_apply_delta (const unsigned char *delta, size_t delta_len,
+                      const unsigned char *src, size_t src_len,
+                      unsigned char **result, size_t *result_len);
+
+/* Parse git binary patch data from the patch file.
+   PFP is the patch file, positioned just after the "GIT binary patch" line.
+   On success, fills in PATCH and returns true.
+   Caller must free forward.data and reverse.data.  */
+bool git_parse_binary_patch (FILE *pfp, struct git_binary_patch *patch);
+
+/* Apply a git binary patch.  INPUT_NAME is the source file (may be null if
+   creating a new file).  OUTFD is the file descriptor for the output file
+   (already opened for writing).
+   PATCH is the parsed binary patch.  REV is true for reverse application.
+   Returns true on success.  */
+bool git_apply_binary_patch (const char *input_name,
+                             int outfd,
+                             const struct git_binary_patch *patch,
+                             bool rev);
+
+/* Free data inside a git_binary_patch struct.  */
+void git_binary_patch_free (struct git_binary_patch *patch);
+
+#endif /* GITPATCH_H */
