+   This program is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+   GNU General Public License for more details.
+
+   You should have received a copy of the GNU General Public License
+   along with this program.  If not, see <http://www.gnu.org/licenses/>.  */
+
+#include <common.h>
+#include <gitpatch.h>
+#include <util.h>
+#include <safe.h>
+#include <xalloc.h>
+#include <quotearg.h>
+#include <pch.h>
+#include <zlib.h>
+
+/* Git's base85 alphabet.  */
+static const char base85_alphabet[] =
+  "0123456789"
+  "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
+  "abcdefghijklmnopqrstuvwxyz"
+  "!#$%&()*+-;<=>?@^_`{|}~";
+
+/* Reverse lookup table for base85 decoding, -1 for invalid.  */
+static signed char base85_decode_tab[256];
+static bool base85_tab_initialized = false;
+
+static void
+init_base85_decode_tab (void)
+{
+  if (base85_tab_initialized)
+    return;
+  memset (base85_decode_tab, -1, sizeof base85_decode_tab);
+  for (int i = 0; i < 85; i++)
+    base85_decode_tab[(unsigned char) base85_alphabet[i]] = i;
+  base85_tab_initialized = true;
+}
+
+/* Decode base85-encoded data.
+   DST must have room for at least LEN bytes.
+   LINE points to the base85-encoded characters (LINE_LEN of them).
+   Returns true on success.  */
+bool
+git_base85_decode (unsigned char *dst, size_t len,
+                   const char *line, size_t line_len)
+{
+  init_base85_decode_tab ();
+
+  size_t dst_pos = 0;
+
+  while (line_len > 0)
+    {
+      /* Need 5 base85 chars to produce 4 bytes (except possibly at end).  */
+      if (line_len < 5)
+        return false;
+
+      unsigned int acc = 0;
+      for (int i = 0; i < 5; i++)
+        {
+          int val = base85_decode_tab[(unsigned char) line[i]];
+          if (val < 0)
+            return false;
+          acc = acc * 85 + val;
+        }
+
+      /* Extract 4 bytes, big-endian.  */
+      unsigned char buf[4];
+      buf[0] = (acc >> 24) & 0xFF;
+      buf[1] = (acc >> 16) & 0xFF;
+      buf[2] = (acc >>  8) & 0xFF;
+      buf[3] = (acc      ) & 0xFF;
+
+      size_t to_copy = len - dst_pos;
+      if (to_copy > 4)
+        to_copy = 4;
+      memcpy (dst + dst_pos, buf, to_copy);
+      dst_pos += to_copy;
+
+      line += 5;
+      line_len -= 5;
+    }
+
+  return dst_pos == len;
+}
+
+/* Decode the length character on a git binary patch data line.
+   Returns the byte count (1..52), or 0 on error.  */
+static size_t
+decode_line_len (char c)
+{
+  if (c >= 'A' && c <= 'Z')
+    return c - 'A' + 1;
+  if (c >= 'a' && c <= 'z')
+    return c - 'a' + 27;
+  return 0;
+}
+
+/* Read a single git binary hunk (either literal or delta).
+   PFP is positioned at the start of the hunk header line
+   (e.g. "literal 1234\n" or "delta 567\n").
+   On success, fills HUNK, advances PFP past the trailing blank line,
+   and returns true.  */
+static bool
+read_binary_hunk (FILE *pfp, struct git_binary_hunk *hunk)
+{
+  char linebuf[4096];
+  if (!fgets (linebuf, sizeof linebuf, pfp))
+    return false;
+
+  /* Parse header: "literal <size>" or "delta <size>".  */
+  size_t result_size;
+  if (strncmp (linebuf, "literal ", 8) == 0)
+    {
+      hunk->type = GIT_BINARY_LITERAL;
+      result_size = strtoul (linebuf + 8, NULL, 10);
+    }
+  else if (strncmp (linebuf, "delta ", 6) == 0)
+    {
+      hunk->type = GIT_BINARY_DELTA;
+      result_size = strtoul (linebuf + 6, NULL, 10);
+    }
+  else
+    return false;
+
+  hunk->result_size = result_size;
+
+  /* Read the base85-encoded, zlib-compressed data lines.
+     Accumulate raw decoded (but still zlib-compressed) bytes.  */
+  size_t raw_alloc = result_size + 256;
+  unsigned char *raw = xmalloc (raw_alloc);
+  size_t raw_len = 0;
+
+  for (;;)
+    {
+      if (!fgets (linebuf, sizeof linebuf, pfp))
+        {
+          free (raw);
+          return false;
+        }
+
+      /* A blank line terminates this hunk.  */
+      if (linebuf[0] == '\n' || (linebuf[0] == '\r' && linebuf[1] == '\n'))
+        break;
+
+      /* Decode length character.  */
+      size_t byte_count = decode_line_len (linebuf[0]);
+      if (byte_count == 0)
+        {
+          free (raw);
+          return false;
+        }
+
+      /* Strip the trailing newline from base85 data.  */
+      size_t b85_len = strlen (linebuf + 1);
+      if (b85_len > 0 && linebuf[1 + b85_len - 1] == '\n')
+        b85_len--;
+      if (b85_len > 0 && linebuf[1 + b85_len - 1] == '\r')
+        b85_len--;
+
+      /* Grow buffer if needed.  */
+      while (raw_len + byte_count > raw_alloc)
+        {
+          raw_alloc *= 2;
+          raw = xrealloc (raw, raw_alloc);
+        }
+
+      if (!git_base85_decode (raw + raw_len, byte_count,
+                              linebuf + 1, b85_len))
+        {
+          free (raw);
+          return false;
+        }
+      raw_len += byte_count;
+    }
+
+  /* Decompress using zlib.  */
+  size_t out_alloc = result_size ? result_size : 1;
+  unsigned char *out = xmalloc (out_alloc);
+
+  z_stream zs;
+  memset (&zs, 0, sizeof zs);
+  zs.next_in = raw;
+  zs.avail_in = raw_len;
+  zs.next_out = out;
+  zs.avail_out = out_alloc;
+
+  if (inflateInit (&zs) != Z_OK)
+    {
+      free (raw);
+      free (out);
+      return false;
+    }
+
+  int ret = inflate (&zs, Z_FINISH);
+  inflateEnd (&zs);
+  free (raw);
+
+  if (ret != Z_STREAM_END)
+    {
+      free (out);
+      return false;
+    }
+
+  hunk->data = out;
+  hunk->data_len = zs.total_out;
+
+  if (hunk->data_len != result_size)
+    {
+      free (out);
+      hunk->data = NULL;
+      hunk->data_len = 0;
+      return false;
+    }
+
+  return true;
+}
+
+/* Parse git binary patch data from the patch file.
+   PFP should be positioned just after the "GIT binary patch\n" line.
+   Returns true on success.  */
+bool
+git_parse_binary_patch (FILE *pfp, struct git_binary_patch *patch)
+{
+  memset (patch, 0, sizeof *patch);
+
+  /* Read the forward hunk.  */
+  if (!read_binary_hunk (pfp, &patch->forward))
+    return false;
+
+  /* Read the reverse hunk.  */
+  if (!read_binary_hunk (pfp, &patch->reverse))
+    {
+      free (patch->forward.data);
+      patch->forward.data = NULL;
+      return false;
+    }
+
+  return true;
+}
+
+/* Read a variable-length size from a delta stream (7 bits per byte,
+   MSB set means more bytes follow).  Returns the size and advances *PP.  */
+static size_t
+read_delta_size (const unsigned char **pp, const unsigned char *end)
+{
+  size_t result = 0;
+  int shift = 0;
+  const unsigned char *p = *pp;
+
+  while (p < end)
+    {
+      unsigned char c = *p++;
+      result |= (size_t)(c & 0x7F) << shift;
+      shift += 7;
+      if (!(c & 0x80))
+        break;
+    }
+
+  *pp = p;
+  return result;
+}
+
+/* Apply a git binary delta.
+   DELTA/DELTA_LEN: the uncompressed delta instruction stream.
+   SRC/SRC_LEN: the original file content.
+   On success, sets *RESULT and *RESULT_LEN, and returns true.
+   Caller must free *RESULT.  */
+bool
+git_apply_delta (const unsigned char *delta, size_t delta_len,
+                 const unsigned char *src, size_t src_len,
+                 unsigned char **result, size_t *result_len)
+{
+  const unsigned char *p = delta;
+  const unsigned char *end = delta + delta_len;
+
+  /* Read source and target sizes from the delta header.  */
+  size_t expected_src_len = read_delta_size (&p, end);
+  size_t target_len = read_delta_size (&p, end);
+
+  if (expected_src_len != src_len)
+    return false;
+
+  unsigned char *out = xmalloc (target_len + 1);
+  size_t out_pos = 0;
+
+  while (p < end)
+    {
+      unsigned char cmd = *p++;
+
+      if (cmd & 0x80)
+        {
+          /* COPY from source.  */
+          size_t offset = 0, size = 0;
+
+          if (cmd & 0x01) { if (p >= end) goto fail; offset  = *p++; }
+          if (cmd & 0x02) { if (p >= end) goto fail; offset |= (size_t)*p++ <<  8; }
+          if (cmd & 0x04) { if (p >= end) goto fail; offset |= (size_t)*p++ << 16; }
+          if (cmd & 0x08) { if (p >= end) goto fail; offset |= (size_t)*p++ << 24; }
+
+          if (cmd & 0x10) { if (p >= end) goto fail; size  = *p++; }
+          if (cmd & 0x20) { if (p >= end) goto fail; size |= (size_t)*p++ <<  8; }
+          if (cmd & 0x40) { if (p >= end) goto fail; size |= (size_t)*p++ << 16; }
+
+          if (size == 0)
+            size = 0x10000;
+
+          if (offset + size > src_len || out_pos + size > target_len)
+            goto fail;
+
+          memcpy (out + out_pos, src + offset, size);
+          out_pos += size;
+        }
+      else if (cmd > 0)
+        {
+          /* ADD literal data.  */
+          size_t size = cmd;
+          if (p + size > end || out_pos + size > target_len)
+            goto fail;
+          memcpy (out + out_pos, p, size);
+          out_pos += size;
+          p += size;
+        }
+      else
+        {
+          /* cmd == 0 is reserved/invalid.  */
+          goto fail;
+        }
+    }
+
+  if (out_pos != target_len)
+    goto fail;
+
+  *result = out;
+  *result_len = target_len;
+  return true;
+
+fail:
+  free (out);
+  *result = NULL;
+  *result_len = 0;
+  return false;
+}
+
+/* Apply a parsed git binary patch.
+   INPUT_NAME: name of source file (NULL if file doesn't exist / new file).
+   OUTFD: file descriptor for the output file (already created by make_tempfile).
+   PATCH: the parsed binary patch.
+   REV: true to apply in reverse.
+   Returns true on success.  */
+bool
+git_apply_binary_patch (const char *input_name,
+                        int outfd,
+                        const struct git_binary_patch *patch,
+                        bool rev)
+{
+  const struct git_binary_hunk *hunk = rev ? &patch->reverse : &patch->forward;
+
+  /* Read the source file (if any).  */
+  unsigned char *src = NULL;
+  size_t src_len = 0;
+
+  if (input_name)
+    {
+      int fd = safe_open ((char *) input_name, O_RDONLY | O_BINARY, 0);
+      if (fd >= 0)
+        {
+          struct stat st;
+          if (fstat (fd, &st) == 0 && S_ISREG (st.st_mode) && st.st_size > 0)
+            {
+              src_len = st.st_size;
+              src = xmalloc (src_len);
+              size_t total = 0;
+              while (total < src_len)
+                {
+                  ssize_t n = read (fd, src + total, src_len - total);
+                  if (n <= 0)
+                    {
+                      free (src);
+                      close (fd);
+                      return false;
+                    }
+                  total += n;
+                }
+            }
+          close (fd);
+        }
+    }
+
+  /* Produce the result.  */
+  unsigned char *result = NULL;
+  size_t result_len = 0;
+
+  if (hunk->type == GIT_BINARY_LITERAL)
+    {
+      /* Literal: the data IS the result.  */
+      result = xmalloc (hunk->data_len + 1);
+      memcpy (result, hunk->data, hunk->data_len);
+      result_len = hunk->data_len;
+    }
+  else if (hunk->type == GIT_BINARY_DELTA)
+    {
+      if (!git_apply_delta (hunk->data, hunk->data_len,
+                            src, src_len,
+                            &result, &result_len))
+        {
+          free (src);
+          say ("git binary delta application failed\n");
+          return false;
+        }
+    }
+
+  free (src);
+
+  /* Write the result file.  */
+  if (dry_run)
+    {
+      free (result);
+      return true;
+    }
+
+  /* Truncate and write to the output fd.  */
+  if (ftruncate (outfd, 0) < 0 || lseek (outfd, 0, SEEK_SET) < 0)
+    {
+      free (result);
+      return false;
+    }
+
+  if (result_len > 0)
+    {
+      size_t written = 0;
+      while (written < result_len)
+        {
+          ssize_t n = write (outfd, result + written, result_len - written);
+          if (n < 0)
+            {
+              free (result);
+              return false;
+            }
+          written += n;
+        }
+    }
+
+  free (result);
+  return true;
+}
+
+/* Free data inside a git_binary_patch struct.  */
+void
+git_binary_patch_free (struct git_binary_patch *patch)
+{
+  free (patch->forward.data);
+  patch->forward.data = NULL;
+  free (patch->reverse.data);
+  patch->reverse.data = NULL;
+}
