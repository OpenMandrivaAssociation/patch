+/* Parse a git binary patch from the current position in the patch file.
+   The patch file should be positioned at the "GIT binary patch" line
+   (via skip_to in there_is_another_patch).
+   On success, fills PATCH and advances past all binary data, returning true.
+   On failure, returns false.  */
+bool
+pch_git_binary_patch (struct git_binary_patch *patch)
+{
+  /* We are positioned right after skip_to, at p_start.
+     Read and skip the "GIT binary patch" header line.  */
+  idx_t chars_read = get_line (true);
+  if (chars_read < 16 || strncmp (patchbuf, "GIT binary patch", 16) != 0)
+    return false;
+
+  /* Parse the binary data (forward + reverse hunks).  */
+  if (!git_parse_binary_patch (pfp, patch))
+    return false;
+
+  /* Record position so intuit knows where the next patch starts.  */
+  off_t pos = Ftello (pfp);
+  next_intuit_at (pos, p_input_line + 1);
+
+  return true;
+}
